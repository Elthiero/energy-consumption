                                        "kind": "DataQuery",
                                        "spec": {
                                            "dataset": "energy_db",
                                            "editorMode": "code",
                                            "format": "table",
                                            "rawQuery": true,
                                            "rawSql": "WITH today AS (\n    SELECT\n        EXTRACT(HOUR FROM bucket AT TIME ZONE 'Africa/Kigali')::int AS hour,\n        SUM(total_energy) / 1000 AS energy_kwh,\n        'Today' AS day\n    FROM energy_readings_hourly\n    WHERE bucket >= DATE_TRUNC('day', NOW() AT TIME ZONE 'Africa/Kigali')\n                      AT TIME ZONE 'Africa/Kigali'\n      AND bucket <= NOW()\n    GROUP BY hour\n),\nyesterday AS (\n    SELECT\n        EXTRACT(HOUR FROM bucket AT TIME ZONE 'Africa/Kigali')::int AS hour,\n        SUM(total_energy) / 1000 AS energy_kwh,\n        'Yesterday' AS day\n    FROM energy_readings_hourly\n    WHERE bucket >= (DATE_TRUNC('day', NOW() AT TIME ZONE 'Africa/Kigali')\n                      AT TIME ZONE 'Africa/Kigali') - INTERVAL '1 day'\n      AND bucket <   DATE_TRUNC('day', NOW() AT TIME ZONE 'Africa/Kigali')\n                      AT TIME ZONE 'Africa/Kigali'\n    GROUP BY hour\n)\nSELECT hour, energy_kwh, day\nFROM today\nUNION ALL\nSELECT hour, energy_kwh, day\nFROM yesterday\nORDER BY day, hour",
                                            "sql": {
                                                "columns": [
                                                    {
                                                        "parameters": [],
                                                        "type": "function"
                                                    }
                                                ],
                                                "groupBy": [
                                                    {
                                                        "property": {
                                                            "type": "string"
                                                        },
                                                        "type": "groupBy"
                                                    }
                                                ],
                                                "limit": 50
                                            }
                                        },
                                        "version": "v0"
                                    },
                                    "refId": "A"
                                }
                            }
                        ],
                        "queryOptions": {},
                        "transformations": []
                    }
                },
