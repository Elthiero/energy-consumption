        "panel-2": {
            "kind": "Panel",
            "spec": {
                "data": {
                    "kind": "QueryGroup",
                    "spec": {
                        "queries": [
                            {
                                "kind": "PanelQuery",
                                "spec": {
                                    "hidden": false,
                                    "query": {
                                        "datasource": {
                                            "name": "efmq8a5gprim8c"
                                        },
