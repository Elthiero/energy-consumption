                                    "hidden": false,
                                    "query": {
                                        "datasource": {
                                            "name": "efmq8a5gprim8c"
                                        },
                                        "group": "grafana-postgresql-datasource",
                                        "kind": "DataQuery",
                                        "spec": {
                                            "dataset": "energy_db",
                                            "editorMode": "code",
                                            "format": "time_series",
                                            "rawQuery": true,
                                            "rawSql": "SELECT\n    $__timeGroupAlias(timestamp, '1m'),\n    meter_id,\n    AVG(power) AS power_w\nFROM energy_readings\nWHERE\n    $__timeFilter(timestamp)\n    AND meter_id IN (\n        SELECT DISTINCT meter_id\n        FROM energy_readings\n        ORDER BY meter_id\n        LIMIT 5\n    )\nGROUP BY 1, meter_id\nORDER BY 1",
                                            "sql": {
                                                "columns": [
                                                    {
                                                        "parameters": [],
                                                        "type": "function"
                                                    }
                                                ],
                                                "groupBy": [
                                                    {
                                                        "property": {
                                                            "type": "string"
                                                        },
                                                        "type": "groupBy"
                                                    }
                                                ],
                                                "limit": 50
                                            }
                                        },
                                        "version": "v0"
                                    },
                                    "refId": "Real-time Power — Last Hour"
                                }
